# PH WiFi Portal — Environment Variables
# Copy to .env and fill in your values

# Application
ENVIRONMENT=production
SECRET_KEY=generate-with-openssl-rand-hex-32

# Database (auto-filled by docker-compose or Zeabur)
DATABASE_URL=postgresql+asyncpg://wifi_admin:PASSWORD@postgres:5432/ph_wifi
POSTGRES_USER=wifi_admin
POSTGRES_PASSWORD=your-secure-password

# Redis (auto-filled by Zeabur)
REDIS_URL=redis://redis:6379/0

# TP-Link OC200 Controller
OMADA_HOST=192.168.1.x        # OC200 local IP
OMADA_PORT=8043
OMADA_CONTROLLER_ID=           # Found in OC200 web URL after login
OMADA_OPERATOR=portal_admin    # Hotspot Manager operator account
OMADA_PASSWORD=                # Operator account password

# Adcash Publisher
ADCASH_ZONE_KEY=               # From Adcash dashboard → Ad Zones

# Admin Dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                # Set a strong password

# Business Rules (optional)
# These are production values. config.py may use different defaults in dev mode.
AD_DURATION_SECONDS=30
SESSION_DURATION_SECONDS=3600  # 1 hour WiFi access
ANTI_SPAM_WINDOW_SECONDS=3600  # 1 hour between ads per device
