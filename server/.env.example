# PH WiFi Portal — Environment Variables
# Copy to .env and fill in your values

# Application
ENVIRONMENT=production
SECRET_KEY=generate-with-openssl-rand-hex-32

# Database (auto-filled by docker-compose or Zeabur)
DATABASE_URL=postgresql+asyncpg://wifi_admin:PASSWORD@postgres:5432/ph_wifi
POSTGRES_USER=wifi_admin
POSTGRES_PASSWORD=your-secure-password

# Redis (auto-filled by Zeabur)
REDIS_URL=redis://redis:6379/0

# Omada Controller
OMADA_HOST=omada              # 自架全套: "omada" | 分開部署: VPS IP | 硬體 OC200: LAN IP
OMADA_PORT=8043
OMADA_CONTROLLER_ID=           # Found in controller web URL after login
OMADA_OPERATOR=portal_admin    # Hotspot Manager operator account
OMADA_PASSWORD=                # Operator account password

# Adcash Publisher
ADCASH_ZONE_KEY=               # From Adcash dashboard → Ad Zones

# Admin Dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                # Set a strong password

# Business Rules (VPA-005 / ADV-004)
AD_DURATION_SECONDS=30            # 30-sec forced video view
SESSION_DURATION_SECONDS=600      # 10 minutes free WiFi
ANTI_SPAM_WINDOW_SECONDS=3600     # 60-min MAC dedup (VPA-005 Art.1.5)

# CPV Rates PHP (ADV-004 Art.4.2)
CPV_VIDEO_PHP=3.00
CPV_IMAGE_PHP=2.00

# DPO Contact (AKD-POL-004)
DPO_EMAIL=privacy@abotkamay.net
